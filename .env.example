# Database - SQLite for local development (or PostgreSQL for production)
# SQLite: DATABASE_URL="file:./dev.db"
# PostgreSQL: DATABASE_URL="postgresql://user:password@localhost:5432/vibe_finance?schema=public"
DATABASE_URL="file:./dev.db"

# AI (Google Gemini) - Get from https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# App
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"
