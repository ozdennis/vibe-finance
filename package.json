{
  "name": "vibe-finance",
  "version": "1.0.0",
  "description": "Personal Wealth Operating System - Track Net Liquidity in Real-Time",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset-seed": "prisma migrate reset && tsx prisma/seed.ts",
    "e2e:build": "npm run build",
    "e2e:test": "node scripts/e2e-runner.js",
    "e2e": "npm run e2e:build && npm run e2e:test",
    "e2e:desktop": "npm run e2e:build && npx playwright test tests/stage3-features.spec.ts --project=\"Desktop Chrome\"",
    "e2e:mobile": "npm run e2e:build && npx playwright test tests/stage3-features.spec.ts --project=\"Mobile Chrome\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "finance",
    "nextjs",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
