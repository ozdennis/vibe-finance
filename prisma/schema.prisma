// prisma/schema.prisma
// Architecture: FBA-SOLID-SSOT | Multi-tenant ledger for Vibe Finance OS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id           String      @id @default(cuid())
  name         String
  type         AccountType
  balance      Decimal     @default(0) @db.Decimal(19, 4)
  creditLimit  Decimal?    @db.Decimal(19, 4)
  currency     String      @default("IDR")

  // Credit Card Billing Cycle (only for CREDIT_CARD type)
  statementDay    Int?     // Day of month when statement is generated (e.g., 5)
  dueDay          Int?     // Day of month when payment is due (e.g., 15)

  // Relations
  outgoingTransfers Transaction[] @relation("SourceAccount")
  incomingTransfers Transaction[] @relation("TargetAccount")
  statements        CreditCardStatement[]
  yieldProfile      AccountYieldProfile?
  interestPostings  InterestPosting[]

  // FBA Strict Audit Baseline (Mandatory)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdById  String
  updatedById  String?
  deletedAt    DateTime?   // For SSOT soft-deletes

  @@index([createdById])
  @@index([type])
}

// Credit Card Statement Tracking
model CreditCardStatement {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id])

  // Statement Period
  statementDate   DateTime // When statement was generated
  startDate       DateTime // Start of billing period
  endDate         DateTime // End of billing period (statement date)
  dueDate         DateTime // Payment due date

  // Amounts
  statementBalance Decimal @db.Decimal(19, 4) // Total balance at statement date
  minimumPayment   Decimal? @db.Decimal(19, 4) // Minimum payment required
  totalPayment     Decimal  @default(0) @db.Decimal(19, 4) // Amount paid so far

  // Status
  isPaid          Boolean  @default(false)
  paidAt          DateTime?

  // Audit
  createdAt       DateTime @default(now())
  createdById     String

  @@index([accountId])
  @@index([createdById])
  @@index([dueDate])
}

model Transaction {
  id             String          @id @default(cuid())
  amount         Decimal         @db.Decimal(19, 4)
  type           TransactionType
  description    String?

  // Transaction Date (for backdating - user selectable)
  date           DateTime        @default(now())

  // Category Relation
  categoryId     String?
  category       Category?       @relation(fields: [categoryId], references: [id])

  // The "Transfer" Logic
  fromAccountId  String?
  fromAccount    Account?        @relation("SourceAccount", fields: [fromAccountId], references: [id])

  toAccountId    String?
  toAccount      Account?        @relation("TargetAccount", fields: [toAccountId], references: [id])

  // Tax & AI Vision Metadata
  isTaxDeductible Boolean        @default(false)
  taxYear        Int?
  metadata       Json?           // Stores Gemini Vision JSON payload

  // Reconciliation Flag (for system-generated true-up transactions)
  isReconciliation Boolean       @default(false)

  // FBA Strict Audit Baseline (Mandatory)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String
  updatedById    String?

  @@index([createdById])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([date])
  @@index([createdById, date])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // e.g., "BALANCE_OVERRIDE", "TRANSACTION_DELETE"
  model      String   // e.g., "Account", "Transaction"
  recordId   String
  payload    Json     // Before/after values
  reason     String?  // User-provided reason

  createdAt  DateTime @default(now())
  createdById String

  @@index([createdById])
  @@index([model, recordId])
}

model Category {
  id          String   @id @default(cuid())
  name        String   // FOOD, TRANSPORT, etc.
  color       String?  // Tailwind class or hex
  icon        String?  // Lucide icon name

  transactions Transaction[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String

  @@unique([name, createdById])
  @@index([createdById])
}

enum AccountType {
  CASH
  E_WALLET
  CREDIT_CARD
  INVESTMENT
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum RateUnit {
  MONTHLY
  YEARLY
}

enum YieldProductType {
  FLEXI
  TIME_DEPOSIT
}

// Yield profile for interest-bearing accounts (CASH and INVESTMENT only)
model AccountYieldProfile {
  id                 String            @id @default(cuid())
  accountId          String            @unique
  account            Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Product type
  productType        YieldProductType  @default(FLEXI)

  // Interest rate configuration
  rateValue          Decimal           @db.Decimal(8, 4)  // e.g., 5.50 for 5.5%
  rateUnit           RateUnit          @default(MONTHLY)  // MONTHLY or YEARLY

  // Tax configuration
  withholdingTaxRatePct Decimal        @default(0) @db.Decimal(5, 2)  // e.g., 20 for 20%

  // Status
  accrualStartDate   DateTime          // When interest starts accruing
  isActive           Boolean           @default(true)

  // Time Deposit fields (nullable, only for TIME_DEPOSIT)
  depositTermMonths  Int?              // allowed: 1,3,6,12 for TIME_DEPOSIT
  depositStartDate   DateTime?
  depositPrincipal   Decimal?          @db.Decimal(19, 4)

  // Audit
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdById        String
  updatedById        String?

  @@index([accountId])
  @@index([createdById])
  @@index([productType])
}

// Interest posting ledger (idempotent monthly postings)
model InterestPosting {
  id              String    @id @default(cuid())
  accountId       String
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  year            Int
  month           Int       // 1-12

  // Interest amounts
  grossInterest   Decimal   @db.Decimal(19, 4)
  taxWithheld     Decimal   @db.Decimal(19, 4)
  netInterest     Decimal   @db.Decimal(19, 4)

  // Links to created transactions
  grossTxId       String?   // Transaction ID for gross interest income
  taxTxId         String?   // Transaction ID for tax withheld expense

  // Metadata
  postedAt        DateTime  @default(now())
  isEstimated     Boolean   @default(false)  // True if MTD estimate, false if actual posting

  // Audit
  createdAt       DateTime  @default(now())
  createdById     String

  @@unique([accountId, year, month])
  @@index([accountId])
  @@index([createdById])
}

// Tax year settings for withheld tax YTD tracking
model TaxYearSetting {
  id              String    @id @default(cuid())
  createdById     String
  year            Int
  
  // Withheld tax YTD (manual input)
  withheldTaxYtd  Decimal   @default(0) @db.Decimal(19, 4)
  
  // Audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([createdById, year])
  @@index([createdById])
}
