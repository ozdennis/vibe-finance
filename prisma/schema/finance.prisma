// prisma/schema/finance.prisma
// Architecture: FBA-SOLID-SSOT | Multi-tenant ledger for Vibe Finance OS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CASH
  E_WALLET
  CREDIT_CARD
  INVESTMENT
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Account {
  id           String      @id @default(cuid())
  name         String
  type         AccountType
  balance      Decimal     @default(0) @db.Decimal(19, 4)
  creditLimit  Decimal?    @db.Decimal(19, 4)
  currency     String      @default("IDR")

  // Credit Card Billing Cycle (only for CREDIT_CARD type)
  statementDay    Int?     // Day of month when statement is generated (e.g., 5)
  dueDay          Int?     // Day of month when payment is due (e.g., 15)
  // Example: Statement 5th → Due 15th = 10 days grace period

  // Relations
  outgoingTransfers Transaction[] @relation("SourceAccount")
  incomingTransfers Transaction[] @relation("TargetAccount")
  statements        CreditCardStatement[]

  // FBA Strict Audit Baseline (Mandatory)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdById  String
  updatedById  String?
  deletedAt    DateTime?   // For SSOT soft-deletes

  @@index([createdById])
  @@index([type])
}

// Credit Card Statement Tracking
model CreditCardStatement {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id])

  // Statement Period
  statementDate   DateTime // When statement was generated
  startDate       DateTime // Start of billing period
  endDate         DateTime // End of billing period (statement date)
  dueDate         DateTime // Payment due date

  // Amounts
  statementBalance Decimal @db.Decimal(19, 4) // Total balance at statement date
  minimumPayment   Decimal? @db.Decimal(19, 4) // Minimum payment required
  totalPayment     Decimal  @default(0) @db.Decimal(19, 4) // Amount paid so far

  // Status
  isPaid          Boolean  @default(false)
  paidAt          DateTime?

  // Audit
  createdAt       DateTime @default(now())
  createdById     String

  @@index([accountId])
  @@index([createdById])
  @@index([dueDate])
}

model Transaction {
  id             String          @id @default(cuid())
  amount         Decimal         @db.Decimal(19, 4)
  type           TransactionType
  description    String?
  categoryId     String?

  // The "Transfer" Logic
  fromAccountId  String?
  fromAccount    Account?        @relation("SourceAccount", fields: [fromAccountId], references: [id])

  toAccountId    String?
  toAccount      Account?        @relation("TargetAccount", fields: [toAccountId], references: [id])

  // Tax & AI Vision Metadata
  isTaxDeductible Boolean        @default(false)
  taxYear        Int?
  metadata       Json?           // Stores Gemini Vision JSON payload

  // FBA Strict Audit Baseline (Mandatory)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String
  updatedById    String?

  @@index([createdById])
  @@index([fromAccountId])
  @@index([toAccountId])
}
